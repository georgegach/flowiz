    "onnxruntime-web": "1.20.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vite-plugin-static-copy": "^1.0.6",
    "@types/pako": "^2.0.3"
  }
